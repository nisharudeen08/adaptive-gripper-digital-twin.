<?xml version="1.0"?>
<robot name="adaptive_gripper_arm">
  <!--
    FULLY CORRECTED URDF for Tabletop Robotic Arm
    - Stands upright at rest (all joints = 0)
    - Clear visual distinction: fat cylinders = joints, slim cylinders = links
    - Total height: ~0.44m from base to gripper
    - Fingers point forward (+X), open/close on Z axis
    - All coordinates in meters, angles in radians
  -->

  <material name="mat_base">
    <color rgba="0.18 0.18 0.20 1.0"/>
  </material>
  <material name="mat_blue">
    <color rgba="0.20 0.45 0.75 1.0"/>
  </material>
  <material name="mat_orange">
    <color rgba="0.85 0.48 0.16 1.0"/>
  </material>
  <material name="mat_silver">
    <color rgba="0.72 0.72 0.74 1.0"/>
  </material>
  <material name="mat_gripper">
    <color rgba="0.16 0.58 0.50 1.0"/>
  </material>

  <!-- World anchor keeps the tabletop base fixed in simulation. -->
  <link name="world"/>

  <!-- ================================================================ -->
  <!-- BASE_LINK: Wide flat platform, sits on ground (Z=0) -->
  <!-- ================================================================ -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <mass value="0.80"/>
      <inertia ixx="0.0011267" ixy="0.0" ixz="0.0" iyy="0.0011267" iyz="0.0" izz="0.0019200"/>
    </inertial>
    <!-- Visual: 0.12(X) × 0.10(Y) × 0.04(Z) box, centered at top surface -->
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.10 0.04"/>
      </geometry>
      <material name="mat_base"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.10 0.04"/>
      </geometry>
    </collision>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <!-- Base frame sits on ground plane at world origin. -->
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================ -->
  <!-- SHOULDER: Joint block (cylinder servo motor shape) on top of base -->
  <!-- Rotates around Z (yaw) for base rotation of arm                  -->
  <!-- ================================================================ -->
  <link name="shoulder_link">
    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <mass value="0.25"/>
      <inertia ixx="0.0001771" ixy="0.0" ixz="0.0" iyy="0.0001771" iyz="0.0" izz="0.0001500"/>
    </inertial>
    <!-- Visual: cylinder R=0.035 L=0.06 along Z (servo housing) -->
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.06" radius="0.035"/>
      </geometry>
      <material name="mat_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.06" radius="0.035"/>
      </geometry>
    </collision>
  </link>

  <!-- Shoulder joint: rotates around Z axis (yaw) ±90° -->
  <joint name="shoulder_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <!-- Shoulder pivot is at the top face of base_link (base height = 0.04 m). -->
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5708" upper="1.5708" effort="4.0" velocity="1.5"/>
    <dynamics damping="0.2" friction="0.08"/>
  </joint>

  <!-- Fixed offset: places upper_arm at top of shoulder cylinder -->
  <joint name="shoulder_to_upper_arm" type="fixed">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <!-- Upper arm root is at the top of shoulder cylinder (shoulder length = 0.06 m). -->
    <origin xyz="0 0 0.06" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================ -->
  <!-- UPPER_ARM: Slim cylinder extending upward (+Z) from shoulder     -->
  <!-- ================================================================ -->
  <link name="upper_arm_link">
    <inertial>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <mass value="0.22"/>
      <inertia ixx="0.0000587" ixy="0.0" ixz="0.0" iyy="0.0006233" iyz="0.0" izz="0.0006233"/>
    </inertial>
    <!-- Visual: slim cylinder R=0.022 L=0.18 along Z (arm segment) -->
    <visual>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.18" radius="0.022"/>
      </geometry>
      <material name="mat_silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.09" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.18" radius="0.022"/>
      </geometry>
    </collision>
  </link>

  <!-- ================================================================ -->
  <!-- ELBOW: Joint block at end of upper arm, rotates forearm in Y     -->
  <!-- ================================================================ -->
  <link name="elbow_link">
    <inertial>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <mass value="0.18"/>
      <inertia ixx="0.0000750" ixy="0.0" ixz="0.0" iyy="0.0000750" iyz="0.0" izz="0.0000750"/>
    </inertial>
    <!-- Visual: cylinder R=0.030 L=0.05 along Z (servo housing) -->
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.030"/>
      </geometry>
      <material name="mat_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.030"/>
      </geometry>
    </collision>
  </link>

  <!-- Elbow joint: rotates around Y axis (pitch) ±90° -->
  <!-- Positioned at Z=0.18 above shoulder joint (top of upper_arm) -->
  <joint name="elbow_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="elbow_link"/>
    <!-- Elbow pivot is at the top end of upper_arm_link (upper arm length = 0.18 m). -->
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="3.0" velocity="1.5"/>
    <dynamics damping="0.18" friction="0.06"/>
  </joint>

  <!-- Fixed offset: places forearm at top of elbow servo -->
  <joint name="elbow_to_forearm" type="fixed">
    <parent link="elbow_link"/>
    <child link="forearm_link"/>
    <!-- Forearm root is at the top of elbow cylinder (elbow length = 0.05 m). -->
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================ -->
  <!-- FOREARM: Medium slim cylinder extending upward from elbow        -->
  <!-- ================================================================ -->
  <link name="forearm_link">
    <inertial>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <mass value="0.18"/>
      <inertia ixx="0.0000368" ixy="0.0" ixz="0.0" iyy="0.0004024" iyz="0.0" izz="0.0004024"/>
    </inertial>
    <!-- Visual: slim cylinder R=0.018 L=0.14 along Z (arm segment) -->
    <visual>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.14" radius="0.018"/>
      </geometry>
      <material name="mat_silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.07" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.14" radius="0.018"/>
      </geometry>
    </collision>
  </link>

  <!-- ================================================================ -->
  <!-- WRIST: Small joint block at end of forearm                      -->
  <!-- ================================================================ -->
  <link name="wrist_link">
    <inertial>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.0000405" ixy="0.0" ixz="0.0" iyy="0.0000405" iyz="0.0" izz="0.0000405"/>
    </inertial>
    <!-- Visual: small cylinder R=0.022 L=0.04 along Z (servo) -->
    <visual>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.022"/>
      </geometry>
      <material name="mat_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.022"/>
      </geometry>
    </collision>
  </link>

  <!-- Wrist joint: rotates around Y axis (pitch) ±90° -->
  <!-- Positioned at Z=0.14 above elbow joint (top of forearm) -->
  <joint name="wrist_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <!-- Wrist pivot is at the top end of forearm_link (forearm length = 0.14 m). -->
    <origin xyz="0 0 0.14" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5708" upper="1.5708" effort="2.0" velocity="2.0"/>
    <dynamics damping="0.12" friction="0.04"/>
  </joint>

  <!-- Fixed offset places gripper base in +X from wrist so palm faces forward. -->
  <joint name="wrist_to_gripper_base" type="fixed">
    <parent link="wrist_link"/>
    <child link="gripper_base_link"/>
    <!-- Gripper base origin is 0.06 m forward from wrist center. -->
    <origin xyz="0.06 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================ -->
  <!-- GRIPPER_BASE (PALM): Flat platform where fingers attach          -->
  <!-- ================================================================ -->
  <link name="gripper_base_link">
    <inertial>
      <origin xyz="0.03 0 0" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="0.0000185" ixy="0.0" ixz="0.0" iyy="0.0000352" iyz="0.0" izz="0.0000433"/>
    </inertial>
    <!-- Visual: flat box 0.06(X: forward) × 0.045(Y: side) × 0.028(Z: height) -->
    <visual>
      <origin xyz="0.03 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.045 0.028"/>
      </geometry>
      <material name="mat_gripper"/>
    </visual>
    <collision>
      <origin xyz="0.03 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.06 0.045 0.028"/>
      </geometry>
    </collision>
  </link>

  <!-- ================================================================ -->
  <!-- FINGER_LEFT: Thin appendage, rotates around Z (open/close)       -->
  <!-- ================================================================ -->
  <link name="finger_left_link">
    <inertial>
      <origin xyz="0.035 0 0" rpy="0 0 0"/>
      <mass value="0.03"/>
      <inertia ixx="0.0000012" ixy="0.0" ixz="0.0" iyy="0.0000131" iyz="0.0" izz="0.0000126"/>
    </inertial>
    <!-- Visual: thin box 0.065(X: length) × 0.011(Y: width) × 0.011(Z: height) -->
    <visual>
      <origin xyz="0.0325 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.065 0.011 0.011"/>
      </geometry>
      <material name="mat_orange"/>
    </visual>
    <collision>
      <origin xyz="0.0325 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.065 0.011 0.011"/>
      </geometry>
    </collision>
  </link>

  <!-- Left finger joint: rotates around Z (open at 0rad, close at ~1.57rad) -->
  <!-- Positioned at X=0.04 (near gripper end) and Y=+0.012 (left side, gap=0.024 between fingers) -->
  <joint name="finger_left_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="finger_left_link"/>
    <!-- Left finger hinge is at front of gripper base, offset +Y for left jaw. -->
    <origin xyz="0.04 0.015 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="1.5708" effort="1.5" velocity="2.0"/>
    <dynamics damping="0.08" friction="0.03"/>
  </joint>

  <!-- ================================================================ -->
  <!-- FINGER_RIGHT: Mirror of left finger, mimics left finger motion   -->
  <!-- ================================================================ -->
  <link name="finger_right_link">
    <inertial>
      <origin xyz="0.035 0 0" rpy="0 0 0"/>
      <mass value="0.03"/>
      <inertia ixx="0.0000012" ixy="0.0" ixz="0.0" iyy="0.0000131" iyz="0.0" izz="0.0000126"/>
    </inertial>
    <!-- Visual: thin box 0.065(X: length) × 0.011(Y: width) × 0.011(Z: height) -->
    <visual>
      <origin xyz="0.0325 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.065 0.011 0.011"/>
      </geometry>
      <material name="mat_orange"/>
    </visual>
    <collision>
      <origin xyz="0.0325 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.065 0.011 0.011"/>
      </geometry>
    </collision>
  </link>

  <!-- Right finger joint: axis inverted (Z→-Z), position mirrored to left -->
  <joint name="finger_right_joint" type="revolute">
    <parent link="gripper_base_link"/>
    <child link="finger_right_link"/>
    <!-- Right finger hinge is at front of gripper base, offset -Y for right jaw. -->
    <origin xyz="0.04 -0.015 0" rpy="0 0 0"/>
    <axis xyz="0 0 -1"/>
    <limit lower="-1.5708" upper="0.0" effort="1.5" velocity="2.0"/>
    <mimic joint="finger_left_joint" multiplier="1.0" offset="0.0"/>
    <dynamics damping="0.08" friction="0.03"/>
  </joint>

  <!-- ================================================================ -->
  <!-- ROS2 CONTROL: Joint state publishers and command interfaces      -->
  <!-- ================================================================ -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="shoulder_joint">
      <command_interface name="position">
        <param name="min">-1.5708</param>
        <param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="elbow_joint">
      <command_interface name="position">
        <param name="min">-1.5708</param>
        <param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="wrist_joint">
      <command_interface name="position">
        <param name="min">-1.5708</param>
        <param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="finger_left_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">1.5708</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="finger_right_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ================================================================ -->
  <!-- GAZEBO PLUGINS AND PHYSICS PROPERTIES                            -->
  <!-- ================================================================ -->
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so" name="gz_ros2_control::GazeboSimROS2ControlPlugin"/>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>100000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <gazebo reference="shoulder_link">
    <material>Gazebo/Blue</material>
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>60000.0</kp>
    <kd>80.0</kd>
  </gazebo>

  <gazebo reference="upper_arm_link">
    <material>Gazebo/White</material>
    <mu1>0.7</mu1>
    <mu2>0.7</mu2>
    <kp>50000.0</kp>
    <kd>70.0</kd>
  </gazebo>

  <gazebo reference="elbow_link">
    <material>Gazebo/Blue</material>
    <mu1>0.7</mu1>
    <mu2>0.7</mu2>
    <kp>50000.0</kp>
    <kd>70.0</kd>
  </gazebo>

  <gazebo reference="forearm_link">
    <material>Gazebo/White</material>
    <mu1>0.7</mu1>
    <mu2>0.7</mu2>
    <kp>50000.0</kp>
    <kd>70.0</kd>
  </gazebo>

  <gazebo reference="wrist_link">
    <material>Gazebo/Blue</material>
    <mu1>0.6</mu1>
    <mu2>0.6</mu2>
    <kp>40000.0</kp>
    <kd>60.0</kd>
  </gazebo>

  <gazebo reference="gripper_base_link">
    <material>Gazebo/Green</material>
    <mu1>0.9</mu1>
    <mu2>0.9</mu2>
    <kp>45000.0</kp>
    <kd>65.0</kd>
  </gazebo>

  <gazebo reference="finger_left_link">
    <material>Gazebo/Orange</material>
    <mu1>1.2</mu1>
    <mu2>1.2</mu2>
    <kp>35000.0</kp>
    <kd>55.0</kd>
  </gazebo>

  <gazebo reference="finger_right_link">
    <material>Gazebo/Orange</material>
    <mu1>1.2</mu1>
    <mu2>1.2</mu2>
    <kp>35000.0</kp>
    <kd>55.0</kd>
  </gazebo>

</robot>
